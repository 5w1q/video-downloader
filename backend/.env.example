# 复制本文件为 .env 后填写真实值，切勿将 .env 提交到 Git
# 按统一基础设施方案（PG + Nginx）配置：
# - 子域名: video.sayhi-ab.asia

# ------------------------------
# 统一网关 / 前端域名
# ------------------------------
APP_PUBLIC_DOMAIN=video.sayhi-ab.asia
FRONTEND_URL=https://video.sayhi-ab.asia
# 逗号分隔；生产建议仅保留正式域名
CORS_ALLOWED_ORIGINS=https://video.sayhi-ab.asia,https://sayhi-ab.asia

# ------------------------------
# 数据库（建议：统一 PostgreSQL；不填则回退本地 SQLite）
# video-downloader 推荐库名：video_app
# ------------------------------
# DATABASE_URL=postgresql://video_app:<password>@<pg-host>:5432/video_app
# 连接池基线（与统一文档一致）
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ---------- AI 总结 / 多轮问答（OpenAI 兼容 Chat Completions；二选一）----------
#
# 【推荐】阿里云百炼 DashScope 兼容模式（与 Paraformer 语音可用同一 DASHSCOPE_API_KEY）
# 控制台开通文本模型后，模型名以 Model Studio 为准（以下为常用名称）。
# SUMMARIZE_LLM_API_KEY=sk-your-dashscope-key
# SUMMARIZE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# SUMMARIZE_LLM_MODEL=qwen-plus
#
# 【备选】DeepSeek（未配置 SUMMARIZE_LLM_API_KEY 时使用）
# 服务器须能访问 https://api.deepseek.com（防火墙/出站策略）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=change-me-to-a-long-random-string

# Stripe 支付（可选）
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id

# --- Ab 主站统一登录与计费（必填）---
# 本地联调：Ab 在 3847，可改为 http://127.0.0.1:3847
# 生产环境：填主站域名 https://sayhi-ab.asia
AB_BASE_URL=https://sayhi-ab.asia
AB_LOGIN_PATH=/login.html
AB_APP_ID=video-downloader
# 可选：主站接口超时（秒）
# AB_TIMEOUT_SEC=20
# 可选：各能力扣费（不填则使用 Ab 主站 apps-registry 默认值）
# AB_CREDITS_COST_DOWNLOAD=0
# AB_CREDITS_COST_SUMMARIZE=3
# AB_CREDITS_COST_CHAT=0
# AB_CREDITS_COST_BULK_DOWNLOAD=0

# --- 阿里云 Paraformer 语音转写（无平台字幕时备用，非 Whisper）---
# 需百炼 API Key（北京）+ 公网站点根 URL（供阿里云下载短时音频；不可用 localhost）
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# PUBLIC_BASE_URL=https://你的域名
# ALIYUN_ASR_MODEL=paraformer-v2
# ALIYUN_ASR_MAX_SECONDS=3600
# ALIYUN_ASR_ENABLED=1

# --- AI 总结：字幕提取阶段超时（秒，含 yt-dlp 与阿里云转写排队）---
# SUMMARIZE_EXTRACT_TIMEOUT_SEC=1200
# SUMMARIZE_EXTRACT_HEARTBEAT_SEC=12
# 抖音：平台字幕/desc 为空时是否再尝试 yt-dlp（常需 Cookie，默认关闭）
# DOUYIN_TRY_YTDLP_SUBTITLES=0

# B 站等：云服务器出口 IP 易返回 HTTP 412。将本机浏览器登录 bilibili.com 后导出的 Netscape 格式
# cookies.txt 放到服务器（勿提交 Git），填写容器内可读绝对路径，例如挂载 /app/secrets/cookies.txt：
# YTDLP_COOKIEFILE=/app/secrets/bilibili_cookies.txt
# 可选别名：BILIBILI_COOKIEFILE（与上一项二选一即可）
# 本地开发可直接复用浏览器 Cookie（Windows 上若报 DPAPI 解密失败，请改回 YTDLP_COOKIEFILE）：
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_BROWSER_PROFILE=Default
# 可选：浏览器指纹模拟（需安装 curl-cffi，可缓解部分 B 站 412）
# YTDLP_IMPERSONATE=chrome
# 解析阶段网络超时（秒，默认 30；仅用于 parse/direct-url，避免前端长时间“解析中”）
# YTDLP_PARSE_SOCKET_TIMEOUT=30
# 若 412 消失后出现「geo-restricted / try a proxy」：多为海外 IP 播控，必须配置可走大陆 B 站的代理，例如：
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# （代理须在容器内可达；若代理在宿主机，勿写 127.0.0.1，应写宿主机在 Docker 网桥上的 IP。）

# Docker / 长期运行：退出进程时不删除 downloads 目录（docker-compose 已默认开启）
# PERSIST_DOWNLOADS=1

# --- 试用期（可选）---
# 若镜像/挂载中存在 backend/keys/trial_public.pem，则必须设置由你方私钥签发的 JWT：
# TRIAL_LICENSE=eyJhbGciOiJSUzI1NiIs...
# 公钥路径覆盖（可选）:
# TRIAL_PUBLIC_KEY_FILE=/app/keys/trial_public.pem
# 调试（可选）:
# TRIAL_GATE_DEBUG=1
